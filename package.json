{
  "name": "testrail-mcp-server-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --filter @testrail-mcp/server test",
    "test:coverage": "pnpm -r --filter @testrail-mcp/server test:coverage",
    "lint": "pnpm -r --filter @testrail-mcp/server lint",
    "format": "pnpm -r --filter @testrail-mcp/server format",
    "format:check": "pnpm -r --filter @testrail-mcp/server format:check",
    "typecheck": "pnpm -r typecheck",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "validate": "pnpm ci",
    "clean": "pnpm -r clean"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
