{
  "name": "testrail-mcp-server",
  "displayName": "TestRail MCP Server",
  "description": "Model Context Protocol server for TestRail — query projects, cases, runs, results, and more from your IDE",
  "version": "0.1.0",
  "publisher": "bhayanak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhayanak/testrail-mcp-server.git",
    "directory": "packages/vscode-extension"
  },
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node build.cjs",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies --allow-missing-repository --skip-license",
    "clean": "rm -rf dist *.vsix"
  },
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "testrail-mcp"
      }
    ],
    "configuration": {
      "title": "TestRail MCP Server",
      "properties": {
        "testrailMcp.apiKey": {
          "type": "string",
          "default": "",
          "description": "TestRail API key (required — generate at My Settings > API Keys)",
          "order": 0
        },
        "testrailMcp.baseUrl": {
          "type": "string",
          "default": "",
          "description": "TestRail instance URL (e.g., https://company.testrail.io)",
          "order": 1
        },
        "testrailMcp.username": {
          "type": "string",
          "default": "",
          "description": "TestRail username (email address)",
          "order": 2
        },
        "testrailMcp.projectId": {
          "type": "string",
          "default": "",
          "description": "Default TestRail project ID (required)",
          "order": 3
        },
        "testrailMcp.timeout": {
          "type": "number",
          "default": 30000,
          "description": "HTTP request timeout in milliseconds",
          "order": 4
        },
        "testrailMcp.maxResults": {
          "type": "number",
          "default": 250,
          "minimum": 1,
          "maximum": 250,
          "description": "Default page size for list queries",
          "order": 5
        },
        "testrailMcp.cacheEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable disk caching for semi-static TestRail data (suites, sections, cases, milestones, users). Speeds up repeated queries significantly.",
          "order": 6
        },
        "testrailMcp.cacheTtlHours": {
          "type": "number",
          "default": 168,
          "minimum": 1,
          "description": "Cache time-to-live in hours (default: 168 = 7 days). Cached data older than this is re-fetched from TestRail.",
          "order": 7
        },
        "testrailMcp.cacheDir": {
          "type": "string",
          "default": "",
          "description": "Directory for disk cache files (default: ~/.testrail-mcp-cache). Leave empty to use the default location.",
          "order": 8
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
